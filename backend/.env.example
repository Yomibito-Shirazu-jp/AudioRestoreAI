# ══════════════════════════════════════════
# AudioRestoreAI Backend Configuration
# Copy this file to .env.local and fill in your keys
# ══════════════════════════════════════════

# ── Server ──
HOST=127.0.0.1
PORT=8000

# ── Google Cloud ──
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=asia-northeast1
GOOGLE_CLOUD_PROJECT=your-gcp-project

# ── LLM API Keys (Deliberation — TRIVIUM 3-Sage) ──
# GRAMMATICA (Engineer) → OpenAI
OPENAI_API_KEY=sk-proj-xxx

# LOGICA (Structure Guard) → Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# RHETORICA (Form Analyst) → Google Gemini
# Uses Application Default Credentials (ADC) for Vertex AI

# ── Anthropic via Vertex AI (optional) ──
ANTHROPIC_USE_VERTEX=false
ANTHROPIC_VERTEX_REGION=global
ANTHROPIC_VERTEX_PROJECT=your-gcp-project

# ── Model Overrides (optional) ──
LOGICA_MODEL=claude-sonnet-4-20250514
GRAMMATICA_FALLBACK=gemini-2.5-flash
RHETORICA_FALLBACK=gemini-2.5-flash
REVIEW_GPT_MODEL=gpt-4.1
